# ─────────────────────────────────────────────────────────────────
#  Planeroo — AI Provider Configuration (example)
#  Copy this file to .env and fill in your real keys.
#  Change AI__Provider to switch the active provider:  OpenAI | Anthropic | Gemini
# ─────────────────────────────────────────────────────────────────

AI__Provider=OpenAI

# ── OpenAI ──────────────────────────────────────────────────────
AI__OpenAI__ApiKey=sk-...
AI__OpenAI__OcrModel=gpt-4o
AI__OpenAI__ChatModel=gpt-4o-mini

# ── Anthropic (Claude) ──────────────────────────────────────────
AI__Anthropic__ApiKey=sk-ant-...
AI__Anthropic__OcrModel=claude-3-5-sonnet-20241022
AI__Anthropic__ChatModel=claude-3-haiku-20240307

# ── Google Gemini ────────────────────────────────────────────────
AI__Gemini__ApiKey=AIza...
AI__Gemini__OcrModel=gemini-1.5-pro
AI__Gemini__ChatModel=gemini-2.0-flash
